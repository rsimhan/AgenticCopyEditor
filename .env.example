# Copy to .env and adjust. .env is gitignored.

# --- Database (matches docker-compose.yml; host port 5433) ---
DATABASE_URL=postgres://ace:ace_dev_password@localhost:5433/ace

# --- LLM provider (reasoning tier: Phase D + reflection agent) ---
# Provider is abstracted behind LlmClient; model id is recorded on every suggestion.
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
LLM_MODEL=claude-opus-4-8

# --- Embedding provider (feedback-memory vectors) ---
# Abstracted behind Embedder; embedding_model is written on every vector row.
EMBEDDING_PROVIDER=gemini
GEMINI_API_KEY=
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=3072

# --- Runtime ---
NODE_ENV=development
LOG_LEVEL=info
# Hard ceiling on reasoning-tier calls per manuscript (cost governance; AGENT-ARCHITECTURE §10).
LLM_CALL_BUDGET_PER_MANUSCRIPT=200
